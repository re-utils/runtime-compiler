{
  "name": "runtime-compiler",
  "version": "4.0.4",
  "description": "A code generation system.",
  "keywords": ["rolldown-plugin", "vite-plugin"],
  "homepage": "",
  "license": "MIT",
  "repository": "re-utils/runtime-compiler",
  "type": "module",
  "scripts": {
    "task": "bun scripts/task.ts",
    "fmt": "oxfmt",
